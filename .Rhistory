tau <- read_csv("../cifar-10h/data/tau.csv")
pi_slow <- read_csv("../cifar-10h/data/pi_slow.csv")
theta_slow <- read_csv("../cifar-10h/data/theta_slow.csv")
tau_slow <- read_csv("../cifar-10h/data/tau_slow.csv")
pi_fast <- read_csv("../cifar-10h/data/pi_fast.csv")
theta_fast <- read_csv("../cifar-10h/data/theta_fast.csv")
tau_fast <- read_csv("../cifar-10h/data/tau_fast.csv")
sort_matrix <- function(array) {
# Sorts an array by the first column.
# :param array: array to sort
# :return: sorted array, matched index
for (col in seq(ncol(array))) {
max_ind <- which.max(array[, col])
array[c(col, max_ind), ] <- array[c(max_ind, col), ]
}
return(array)
}
theta <- sort_matrix(as.matrix(theta))
theta_slow <- sort_matrix(as.matrix(theta_slow))
theta_fast <- sort_matrix(as.matrix(theta_fast))
names(pi) <- names(pi_slow) <- names(pi_fast) <- c("pi")
colnames(theta) <- colnames(theta_slow) <- colnames(theta_fast) <- Y_cifar10h %>% dplyr::select(-image_filename, -J) %>% names()
rownames(theta) <- rownames(theta_slow) <- rownames(theta_fast) <- colnames(theta)
names(tau) <- names(theta)
